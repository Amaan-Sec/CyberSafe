# Copy to .env and fill in your own keys. Never commit .env.

# VirusTotal — https://www.virustotal.com/gui/my-apikey
# Used by server.py for URL safety lookups. Free tier: 4 req/min, 500/day.
VT_API_KEY=

# Sarvam AI — https://dashboard.sarvam.ai/admin/api-keys
# Used by the Flutter app for Indic TTS. If empty, falls back to flutter_tts.
# Pass to the build:  flutter build apk --dart-define=SARVAM_KEY=$SARVAM_KEY
SARVAM_KEY=
